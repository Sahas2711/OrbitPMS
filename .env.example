# ═══════════════════════════════════════════════════════════════
# OrbitPMS - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/orbitpms

# ── App ───────────────────────────────────────────────────────
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Hotel (used in invoice PDFs) ──────────────────────────────
HOTEL_NAME=OrbitPMS Hotel & Suites
HOTEL_ADDRESS=123 Hospitality Drive
HOTEL_CITY_STATE_ZIP=San Francisco, CA 94105
HOTEL_PHONE=+1-555-ORBIT (67248)
HOTEL_EMAIL=stay@orbitpms.com
HOTEL_WEBSITE=www.orbitpms.com

# ── Tax ───────────────────────────────────────────────────────
DEFAULT_TAX_RATE=0.10

# ── Invoice PDF storage (local) ───────────────────────────────
INVOICE_STORAGE_PATH=storage/invoices

# ── CORS (frontend origins allowed by the API) ────────────────
# Comma-separated list of frontend URLs the backend will accept.
#   Local dev:   http://localhost:5173,http://127.0.0.1:5173
#   Production:  https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ═══════════════════════════════════════════════════════════════
# DEPLOYMENT — Backend on Render, Frontend on Vercel
# ═══════════════════════════════════════════════════════════════
#
# 1. Create a Render Web Service from this repo:
#    - Build command: pip install -r backend/requirements.txt
#    - Start command: uvicorn app.main:app --host 0.0.0.0 --port $PORT
#    - Set env vars: DATABASE_URL, SECRET_KEY, CORS_ORIGINS
#
# 2. Deploy the frontend to Vercel:
#    - Connect the same repo, output dir: frontend/dist
#    - Set env var: VITE_API_URL = https://your-render-backend.onrender.com
#    (Leave empty / unset for local dev — Vite proxy handles it)
# ═══════════════════════════════════════════════════════════════

# ── Frontend API URL (Vercel env var for production) ──────────
# Set this in Vercel project dashboard -> Environment Variables:
#   VITE_API_URL = https://your-app.onrender.com
# Leave unset locally — Vite proxy forwards /api to port 8000.
# VITE_API_URL=
